# Codex ↔ Feishu Configuration
# Copy to the legacy data path ~/.claude-to-im/config.env and edit.

CTI_RUNTIME=codex
CTI_ENABLED_CHANNELS=feishu
CTI_DEFAULT_WORKDIR=/path/to/your/project

# Optional; inherits runtime default if not set.
# CTI_DEFAULT_MODEL=

# code, plan, ask
CTI_DEFAULT_MODE=code

# Codex auth (optional — only if not using `codex auth login`)
# Priority: CTI_CODEX_API_KEY > CODEX_API_KEY > OPENAI_API_KEY
# CTI_CODEX_API_KEY=
# CTI_CODEX_BASE_URL=
# CTI_CODEX_SKIP_GIT_REPO_CHECK=true

# Feishu app credentials
CTI_FEISHU_APP_ID=your-app-id
CTI_FEISHU_APP_SECRET=your-app-secret
# CTI_FEISHU_DOMAIN=https://open.feishu.cn
# CTI_FEISHU_ALLOWED_USERS=user_id_1,user_id_2

# Permission behavior
# Only enable auto-approve in trusted, access-controlled environments.
# CTI_AUTO_APPROVE=true

# Compatibility note:
# Older runtimes and non-Feishu channels may still exist in code, but they are not
# part of this template because the maintained product path is Codex ↔ Feishu.
